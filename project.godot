; Project was converted by built-in tool to Godot 4
; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Genso Battle"
run/main_scene="res://ui/main_menu/stack_based_main_menu.tscn"
boot_splash/image="res://assets/ui/splash_screen.png"
config/icon="res://icon.png"
config/windows_native_icon="res://icon.ico"

[autoload]

Utils="*res://utils.gd"
Enums="*res://enums.gd"
Events="*res://events.gd"
Loader="*res://loader.gd"
GameData="*res://save_data/game_data.gd"
AntialiasedLine2DTexture="*res://addons/antialiased_line2d/texture.gd"

[debug]

gdscript/warnings/unused_signal=false

[display]

window/size/viewport_width=720
window/size/viewport_height=960
window/dpi/allow_hidpi=true
window/handheld/orientation="portrait"
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PackedStringArray( "res://addons/antialiased_line2d/plugin.cfg", "res://addons/battle_info_provider/plugin.cfg" )

[gui]

common/drop_mouse_on_gui_input_disabled=true
theme/use_hidpi=true

[input]

ui_select={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"command":false,"pressed":false,"keycode":32,"physical_keycode":0,"unicode":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":0,"button_index":3,"pressure":0.0,"pressed":false,"script":null)
, Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"command":false,"button_mask":0,"position":Vector2( 0, 0 ),"global_position":Vector2( 0, 0 ),"factor":1.0,"button_index":1,"pressed":false,"double_click":false,"script":null)
 ]
}

[layer_names]

2d_physics/layer_1="bounds"
2d_physics/layer_2="player"
2d_physics/layer_3="cell"
2d_physics/layer_4="enemy"

[internationalization]

locale/translations=PackedStringArray("res://text/text.en.translation", "res://text/text.es.translation")
locale/fallback="en"

[network]

limits/debugger/max_chars_per_second=10000

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=false
environment/defaults/default_environment="res://default_env.tres"
